{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git",
      "functions/**",
      "node_modules/**",
      "tools/**",
      "README.md",
      "*.docx"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/landing.html"
      },
      {
        "source": "/checkout/success",
        "destination": "/landing.html"
      },
      {
        "source": "/checkout/cancel",
        "destination": "/landing.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git"
      ]
    }
  ]
}
